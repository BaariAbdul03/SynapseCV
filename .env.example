# ==============================================================================
# SynapseCV Enterprise Environment Configuration Template
# Copy this file to `.env` in the root directory and supply your actual keys.
# DO NOT commit your `.env` file containing secret keys to Git.
# ==============================================================================

# Flask Settings
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=generate_a_random_secure_secret_key_here

# Google Gemini API Credentials
# Get your Gemini API Key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_actual_gemini_api_key_here

# Database Settings
# Defaults to local SQLite file: instance/synapsecv.db
# For PostgreSQL/Supabase, uncomment and specify:
# DATABASE_URL=postgresql://user:password@host:port/dbname

# OAuth Settings (Optional, for Google Sign-In)
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here
